```gitignore
# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# macOS
.DS_Store

# IDEs
.vscode/
.idea/

# Environment variables
.env

# SQLite databases
*.db
*.sqlite
*.sqlite3

# Logs
*.log

# Test & coverage
.pytest_cache/
.coverage
htmlcov/

# Packet captures / evidence
captures/*.pcap

# Build artifacts
build/
dist/
*.egg-info/

# OS-generated files
Thumbs.db
```
